# Required runtime database profile.
# Point this at the prepared Supabase/Postgres runtime database before using docker compose.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
JWT_SECRET=local-dev-secret-do-not-use-in-production
STARTUP_DATA_MODE=validate
DEMO_MODE=false
API_PORT=3001
# Render sets PORT automatically for hosted web services. Local Docker uses API_PORT.
# PORT=10000
DATABASE_SSL_REJECT_UNAUTHORIZED=false
FRONTEND_ORIGIN=http://localhost:5173

# Local app against Supabase profile.
# Use the direct Supabase URL for one-off restore/migration work.
# Use the pooled/runtime Supabase URL for normal API runtime when deploying.
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
# SUPABASE_DIRECT_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
# STARTUP_DATA_MODE=validate
# DEMO_MODE=false
# FRONTEND_ORIGIN=http://localhost:5173

# Optional local Postgres profile for non-compose backend work only.
# POSTGRES_DB=qaviewer
# POSTGRES_USER=qaviewer
# POSTGRES_PASSWORD=qaviewer
# DATABASE_URL=postgres://qaviewer:qaviewer@localhost:5432/qaviewer

# Prepared database dump/restore helpers.
# PREPARED_DUMP_PATH=../qaviewer-prepared.dump
# PREPARED_DB_CONTAINER=qaviewer-db-1
# PREPARED_RESTORE_MODE=app-data
# PG_RESTORE_BIN=pg_restore
# PG_RESTORE_DOCKER_DNS=1.1.1.1,8.8.8.8

PROPERTY_TAX_PARCEL_WORKBOOK_PATH=PropertyTax Map implementation/ParcelsListingReport.xlsx
REGRID_FEATURE_SERVICE_URL=
VITE_REGRID_FEATURE_SERVICE_URL=
PROPERTY_TAX_REGRID_MIN_ZOOM=12
